rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_SAINT' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_USER'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'username', 'role', 'createdAt']) &&
               data.uid is string &&
               data.username is string &&
               data.role in ['ADMIN', 'REGULAR', 'SUPER_SAINT', 'SUPER_USER'] &&
               data.createdAt is number;
      }

      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(request.resource.data) &&
                      (request.resource.data.role == 'REGULAR' || request.auth.token.email in ['developertarbiyahcare@gmail.com', 'nvardi75@gmail.com']);
      
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) &&
                      (
                        // Regular user can't change their own role unless they are the bootstrap admins
                        (isOwner(userId) && request.resource.data.role == resource.data.role) ||
                        isAdmin() ||
                        (request.auth.token.email in ['developertarbiyahcare@gmail.com', 'nvardi75@gmail.com'])
                      );
    }

    // Patients Collection
    match /patients/{patientId} {
      allow read: if isSignedIn() && (resource.data.authorUid == request.auth.uid || isAdmin());
      
      function isValidPatient(data) {
        return data.keys().hasAll(['id', 'authorUid', 'patientName', 'timestamp']) &&
               data.id is string &&
               data.authorUid == request.auth.uid &&
               data.patientName is string &&
               data.patientName.size() > 0 &&
               data.timestamp is number;
      }

      allow create: if isSignedIn() && isValidPatient(request.resource.data);
      allow update: if isSignedIn() && (resource.data.authorUid == request.auth.uid || isAdmin()) && isValidPatient(request.resource.data);
      allow delete: if isSignedIn() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // Settings Collection
    match /settings/config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
